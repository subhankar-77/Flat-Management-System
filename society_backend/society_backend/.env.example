# ─────────────────────────────────────────────────────────────
#  SocietyPay — Environment Variables
#  Copy this file to .env and fill in YOUR values.
#  NEVER commit .env to git. Add it to .gitignore.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
# Local:  postgresql://postgres:yourpassword@localhost:5432/society_db
# Render: get URL from Render dashboard → your PostgreSQL service
# Supabase: Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/society_db

# ── JWT Secret ────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Admin Account (used by /api/auth/seed-admin) ──────────────
ADMIN_EMAIL=admin@sunriseheights.com
ADMIN_PASSWORD=ChangeThisPassword@123
ADMIN_NAME=Society Admin

# ── Razorpay ─────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use test keys (rzp_test_...) during development
# Switch to live keys (rzp_live_...) before going live
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Society ───────────────────────────────────────────────────
SOCIETY_NAME=Sunrise Heights Society
SOCIETY_TOTAL_FLATS=9
DEFAULT_MAINTENANCE_CHARGE=3000
